SECRET_KEY=your-secret-key-here
DEBUG=True

# Local PostgreSQL (dev)
DATABASE_URL=postgres://postgres:yourpassword@localhost/pathfind_dev

# NeonDB (production) — replace with your Neon connection string
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/pathfind?sslmode=require

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------------------------
# AWS S3 — Document storage (set USE_S3=True to enable)
# ---------------------------------------------------------------------------
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_STORAGE_BUCKET_NAME=pathfind-documents
AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-cloudfront-domain.cloudfront.net
# AWS_PRESIGNED_EXPIRY=3600

# ---------------------------------------------------------------------------
# Celery — async task queue & scheduled fetching
# Requires a running Redis instance (default port 6379).
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Job-board API credentials
# Sign up for free developer accounts and paste the keys below.
# Providers without keys are skipped silently — no errors.
# ---------------------------------------------------------------------------

# Adzuna — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb

# Jooble — https://jooble.org/api/about
JOOBLE_API_KEY=

# Careerjet — https://www.careerjet.com/partners/api/
CAREERJET_AFFID=
CAREERJET_LOCALE=en_GB
